APP_NAME=SERDOS_Digital_Nusantara
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:1111

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=serdos_digital
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_DRIVER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@serdos.local
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=serdos-app
REVERB_APP_KEY=serdos-secret-key
REVERB_APP_SECRET=serdos-app-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb

MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

AI_ENGINE_URL=http://127.0.0.1:5000
AI_ENGINE_TIMEOUT=30

TELESCOPE_ENABLED=false
